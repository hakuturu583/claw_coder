#!/usr/bin/env bash
set -euo pipefail

PROGRAM="${0##*/}"
INSTANCE="${NEMOLXD_INSTANCE:-nemoclaw-vllm}"
SERVICE="nemolxd-llama.service"
IMAGE="${NEMOLXD_IMAGE:-ubuntu:24.04}"
MODEL="${NEMOLXD_MODEL:-unsloth/Qwen3.6-35B-A3B-GGUF:UD-Q4_K_M}"
TOKENIZER="${NEMOLXD_TOKENIZER:-Qwen/Qwen3.6-35B-A3B}"
HF_CONFIG_PATH="${NEMOLXD_HF_CONFIG_PATH:-Qwen/Qwen3.6-35B-A3B}"
HF_OVERRIDES="${NEMOLXD_HF_OVERRIDES:-}"
GGUF_FILE="${NEMOLXD_GGUF_FILE:-}"
API_HOST="${NEMOLXD_API_HOST:-127.0.0.1}"
API_PORT="${NEMOLXD_API_PORT:-8000}"
HOST_PORT="${NEMOLXD_HOST_PORT:-none}"
GPU_ID="${NEMOLXD_GPU_ID:-nvidia.com/gpu=all}"
TP_SIZE="${NEMOLXD_TENSOR_PARALLEL_SIZE:-1}"
MAX_MODEL_LEN="${NEMOLXD_MAX_MODEL_LEN:-32768}"
CUDA_VARIANT="${NEMOLXD_CUDA_VARIANT:-cu130}"
LLAMA_CPP_TAG="${NEMOLXD_LLAMA_CPP_TAG:-b9803}"
LLAMA_N_GPU_LAYERS="${NEMOLXD_LLAMA_N_GPU_LAYERS:-999}"
PASS_HF_TOKEN=0

usage() {
  cat <<EOF
Usage: $PROGRAM [global options] <command>

Build and run an isolated llama.cpp coding-agent runtime inside LXD.

Global options:
  --instance NAME        LXD instance name (default: $INSTANCE)
  --image IMAGE          LXD image (default: $IMAGE)
  --model MODEL          GGUF model id/path (default: $MODEL)
  --tokenizer MODEL      tokenizer repo/path (default: $TOKENIZER)
  --hf-config-path MODEL  Deprecated compatibility option (default: $HF_CONFIG_PATH)
  --hf-overrides JSON    Deprecated compatibility option
  --gguf-file NAME       GGUF filename in the model repo
  --api-port PORT        llama.cpp port inside the container (default: $API_PORT)
  --host-port PORT       Optional host localhost proxy port, or "none" (default: $HOST_PORT)
  --gpu-id ID            LXD CDI GPU id, "auto", or "none" (default: $GPU_ID)
  --tp-size N            Deprecated compatibility option (default: $TP_SIZE)
  --max-model-len N      llama.cpp context size (default: $MAX_MODEL_LEN)
  --cuda-variant NAME    CUDA toolkit variant for llama.cpp build: cu130, cpu (default: $CUDA_VARIANT)
  --llama-cpp-tag TAG    llama.cpp release tag or git ref (default: $LLAMA_CPP_TAG)
  --n-gpu-layers N       llama.cpp GPU offload layers (default: $LLAMA_N_GPU_LAYERS)
  --pass-hf-token        Pass only HF_TOKEN/HUGGING_FACE_HUB_TOKEN into setup
  -h, --help             Show help

Commands:
  init-host              Run "lxd init --auto" when LXD has no default profile
  doctor                 Check host-side requirements
  create                 Create the LXD container and attach GPU/proxy devices
  install                Install/build llama.cpp and local agent endpoint config
  up                     create + install + start
  start                  Start the llama.cpp systemd service inside LXD
  stop                   Stop the llama.cpp service
  status                 Show LXD and service status
  logs                   Follow llama.cpp service logs
  test                   Query /v1/models inside LXD, or through host proxy if enabled
  shell                  Open a scrubbed-env root shell in the container
  destroy                Delete the container

Environment overrides use the NEMOLXD_* variables matching the option names.
EOF
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

have() {
  command -v "$1" >/dev/null 2>&1
}

lxc_exists() {
  lxc info "$INSTANCE" >/dev/null 2>&1
}

remote_env() {
  local token="${HF_TOKEN:-${HUGGING_FACE_HUB_TOKEN:-}}"
  local host_cuda
  host_cuda="$(cuda_version_number || true)"
  local -a env_args=(
    env -i
    HOME=/root
    USER=root
    LOGNAME=root
    SHELL=/bin/bash
    LANG=C.UTF-8
    LC_ALL=C.UTF-8
    PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    NEMOLXD_MODEL="$MODEL"
    NEMOLXD_TOKENIZER="$TOKENIZER"
    NEMOLXD_HF_CONFIG_PATH="$HF_CONFIG_PATH"
    NEMOLXD_HF_OVERRIDES="$HF_OVERRIDES"
    NEMOLXD_GGUF_FILE="$GGUF_FILE"
    NEMOLXD_API_HOST="$API_HOST"
    NEMOLXD_API_PORT="$API_PORT"
    NEMOLXD_TENSOR_PARALLEL_SIZE="$TP_SIZE"
    NEMOLXD_MAX_MODEL_LEN="$MAX_MODEL_LEN"
    NEMOLXD_CUDA_VARIANT="$CUDA_VARIANT"
    NEMOLXD_HOST_CUDA_VERSION="$host_cuda"
    NEMOLXD_LLAMA_CPP_TAG="$LLAMA_CPP_TAG"
    NEMOLXD_LLAMA_N_GPU_LAYERS="$LLAMA_N_GPU_LAYERS"
  )
  if [[ "$PASS_HF_TOKEN" == 1 && -n "$token" ]]; then
    env_args+=(HF_TOKEN="$token" HUGGING_FACE_HUB_TOKEN="$token")
  fi
  lxc exec "$INSTANCE" -- "${env_args[@]}" "$@"
}

remote_bash() {
  remote_env bash -s
}

require_lxc() {
  have lxc || die "lxc command is not installed or not on PATH"
}

has_default_root_disk() {
  lxc profile show default 2>/dev/null | grep -q 'path: /' &&
    lxc profile show default 2>/dev/null | grep -q 'type: disk'
}

has_storage_pool() {
  lxc storage list --format csv 2>/dev/null | grep -q .
}

cuda_version_number() {
  nvidia-smi 2>/dev/null | sed -n 's/.*CUDA Version: \([0-9][0-9]*\.[0-9][0-9]*\).*/\1/p' | head -n 1
}

cuda_at_least() {
  local current="$1"
  local required="$2"
  awk -v current="$current" -v required="$required" 'BEGIN {
    split(current, c, "."); split(required, r, ".");
    exit !((c[1] + 0) > (r[1] + 0) || ((c[1] + 0) == (r[1] + 0) && (c[2] + 0) >= (r[2] + 0)))
  }'
}

check_cuda_variant_supported() {
  local variant="$1"
  local required=""
  case "$variant" in
    cpu|none) return 0 ;;
    cu129) required="12.9" ;;
    cu130) required="13.0" ;;
    cu126) required="12.6" ;;
    cu118) required="11.8" ;;
    pypi) return 0 ;;
    *) die "unsupported CUDA variant: $variant" ;;
  esac

  local current
  current="$(cuda_version_number || true)"
  [[ -n "$current" ]] || die "could not detect CUDA version from nvidia-smi"
  if ! cuda_at_least "$current" "$required"; then
    if [[ "${NEMOLXD_ALLOW_UNSUPPORTED_DRIVER:-0}" == 1 ]]; then
      printf 'warning: CUDA %s is below required %s for %s; continuing because NEMOLXD_ALLOW_UNSUPPORTED_DRIVER=1\n' "$current" "$required" "$variant" >&2
      return 0
    fi
    die "NVIDIA driver exposes CUDA $current, but llama.cpp $variant build needs CUDA $required or newer. Update the host NVIDIA driver, or set --cuda-variant cpu intentionally."
  fi
}

cmd_init_host() {
  require_lxc
  if has_default_root_disk && has_storage_pool; then
    printf 'LXD host already initialized.\n'
    return 0
  fi
  lxd init --auto
  printf 'LXD host initialized with automatic defaults.\n'
}

cmd_doctor() {
  require_lxc
  printf 'lxc: %s\n' "$(lxc version 2>/dev/null | head -n 1 || true)"
  lxc profile show default >/dev/null || die "LXD is not initialized for this user. Run: lxd init"
  has_storage_pool || die "LXD has no storage pool. Run: $PROGRAM init-host"
  has_default_root_disk || die "LXD default profile has no root disk. Run: $PROGRAM init-host"
  if have nvidia-smi; then
    nvidia-smi -L || true
    check_cuda_variant_supported "$CUDA_VARIANT"
  else
    printf 'nvidia-smi: not found; GPU passthrough can still work if LXD CDI devices are configured.\n'
  fi
  printf 'doctor: ok\n'
}

cmd_create() {
  require_lxc
  has_storage_pool || die "LXD has no storage pool. Run: $PROGRAM init-host"
  has_default_root_disk || die "LXD default profile has no root disk. Run: $PROGRAM init-host"
  local created=0
  local was_running=0
  if ! lxc_exists; then
    lxc init "$IMAGE" "$INSTANCE"
    created=1
  fi

  if lxc info "$INSTANCE" 2>/dev/null | grep -qi '^Status: running'; then
    was_running=1
  fi

  if [[ "$created" == 0 && "$was_running" == 1 ]]; then
    if [[ "$GPU_ID" != "none" ]] && ! lxc config device show "$INSTANCE" | grep -q '^gpu:'; then
      lxc stop "$INSTANCE"
      was_running=0
    fi
  fi

  if [[ "$created" == 1 || "$was_running" == 0 ]]; then
    lxc config set "$INSTANCE" security.nesting true
    lxc config set "$INSTANCE" security.syscalls.intercept.mknod true || true
    lxc config set "$INSTANCE" security.syscalls.intercept.setxattr true || true
  else
    lxc config set "$INSTANCE" security.nesting true
    lxc config set "$INSTANCE" security.syscalls.intercept.mknod true || true
    lxc config set "$INSTANCE" security.syscalls.intercept.setxattr true || true
  fi

  if [[ "$GPU_ID" != "none" ]] && ! lxc config device show "$INSTANCE" | grep -q '^gpu:'; then
    if [[ "$GPU_ID" == "auto" ]]; then
      lxc config device add "$INSTANCE" gpu gpu gputype=physical
    else
      lxc config device add "$INSTANCE" gpu gpu gputype=physical id="$GPU_ID"
    fi
  fi

  if [[ "$HOST_PORT" == "none" || -z "$HOST_PORT" ]]; then
    if lxc config device show "$INSTANCE" | grep -q '^vllm-api:'; then
      lxc config device remove "$INSTANCE" vllm-api || true
    fi
    if lxc config device show "$INSTANCE" | grep -q '^llama-api:'; then
      lxc config device remove "$INSTANCE" llama-api || true
    fi
  else
    if lxc config device show "$INSTANCE" | grep -q '^vllm-api:'; then
      lxc config device remove "$INSTANCE" vllm-api || true
    fi
    if ! lxc config device show "$INSTANCE" | grep -q '^llama-api:'; then
      lxc config device add "$INSTANCE" llama-api proxy \
      listen="tcp:127.0.0.1:${HOST_PORT}" \
      connect="tcp:${API_HOST}:${API_PORT}"
    fi
  fi

  if [[ "$created" == 1 || "$was_running" == 0 ]]; then
    lxc start "$INSTANCE"
  fi

  lxc exec "$INSTANCE" -- cloud-init status --wait >/dev/null 2>&1 || true
  printf 'created: %s\n' "$INSTANCE"
}

cmd_install() {
  require_lxc
  lxc_exists || die "instance does not exist: $INSTANCE"

  remote_bash <<'REMOTE'
set -euo pipefail
export DEBIAN_FRONTEND=noninteractive

apt-get update
apt-get install -y --no-install-recommends \
  bash build-essential ca-certificates cmake curl git jq python3 python3-pip python3-venv tini

install -d -m 0755 /opt/nemolxd /opt/nemoclaw /var/lib/nemolxd
rm -rf /opt/nemolxd/venv
python3 -m venv /opt/nemolxd/venv
. /opt/nemolxd/venv/bin/activate
python -m pip install --upgrade pip wheel "setuptools<80,>=77.0.3"
python -m pip install huggingface_hub openai

case "${NEMOLXD_CUDA_VARIANT}" in
  cu130)
    required_cuda="${NEMOLXD_CUDA_VARIANT#cu}"
    required_cuda="${required_cuda:0:2}.${required_cuda:2:1}"
    current_cuda="${NEMOLXD_HOST_CUDA_VERSION:-}"
    if [ -z "$current_cuda" ]; then
      current_cuda="$(nvidia-smi 2>/dev/null | sed -n 's/.*CUDA Version: \([0-9][0-9]*\.[0-9][0-9]*\).*/\1/p' | head -n 1 || true)"
    fi
    if [ -z "$current_cuda" ]; then
      echo "could not detect CUDA version from host or container nvidia-smi" >&2
      exit 1
    fi
    if ! awk -v current="$current_cuda" -v required="$required_cuda" 'BEGIN { split(current,c,"."); split(required,r,"."); exit !((c[1]+0)>(r[1]+0)||((c[1]+0)==(r[1]+0)&&(c[2]+0)>=(r[2]+0))) }'; then
      if [ "${NEMOLXD_ALLOW_UNSUPPORTED_DRIVER:-0}" != "1" ]; then
        echo "NVIDIA driver exposes CUDA ${current_cuda}, but llama.cpp ${NEMOLXD_CUDA_VARIANT} build needs CUDA ${required_cuda} or newer." >&2
        echo "Update the host NVIDIA driver, set --cuda-variant cpu, or set NEMOLXD_ALLOW_UNSUPPORTED_DRIVER=1 to force installation." >&2
        exit 1
      fi
    fi
    python -m pip install \
      nvidia-cuda-cccl nvidia-cuda-nvcc nvidia-cuda-runtime nvidia-cuda-nvrtc nvidia-cublas nvidia-curand \
      nvidia-cusolver nvidia-cusparse nvidia-nvjitlink nvidia-nvtx
    cuda_root="/opt/nemolxd/venv/lib/python3.12/site-packages/nvidia/cu13"
    for lib in "$cuda_root"/lib/*.so.*; do
      base="${lib%%.so.*}.so"
      [ -e "$base" ] || ln -s "${lib##*/}" "$base"
    done
    build_cuda=1
    ;;
  cpu|none|pypi)
    build_cuda=0
    ;;
  *)
    echo "unsupported NEMOLXD_CUDA_VARIANT: ${NEMOLXD_CUDA_VARIANT}" >&2
    exit 1
    ;;
esac

llama_model_path="$NEMOLXD_MODEL"
if [[ "$NEMOLXD_MODEL" == *:* ]]; then
  model_repo="${NEMOLXD_MODEL%%:*}"
  quant_name="${NEMOLXD_MODEL#*:}"
  gguf_file="${NEMOLXD_GGUF_FILE:-}"
  if [ -z "$gguf_file" ]; then
    repo_base="${model_repo##*/}"
    repo_base="${repo_base%-GGUF}"
    gguf_file="${repo_base}-${quant_name}.gguf"
  fi
  install -d -m 0755 /var/lib/nemolxd/models
  llama_model_path="$(python - "$model_repo" "$gguf_file" <<'PY'
import sys
from huggingface_hub import hf_hub_download
repo, filename = sys.argv[1], sys.argv[2]
print(hf_hub_download(repo_id=repo, filename=filename,
                      local_dir="/var/lib/nemolxd/models",
                      local_dir_use_symlinks=False))
PY
)"
fi

llama_tag="${NEMOLXD_LLAMA_CPP_TAG:-b9803}"
rm -rf /opt/nemolxd/llama.cpp /opt/nemolxd/llama-build
git clone --depth 1 --branch "$llama_tag" https://github.com/ggml-org/llama.cpp.git /opt/nemolxd/llama.cpp

cmake_args=(
  -S /opt/nemolxd/llama.cpp
  -B /opt/nemolxd/llama-build
  -DCMAKE_BUILD_TYPE=Release
  -DLLAMA_CURL=OFF
)
if [ "$build_cuda" = 1 ]; then
  cuda_root="/opt/nemolxd/venv/lib/python3.12/site-packages/nvidia/cu13"
  cmake_args+=(
    -DGGML_CUDA=ON
    -DCMAKE_CUDA_COMPILER="${cuda_root}/bin/nvcc"
    -DCUDAToolkit_ROOT="${cuda_root}"
    -DCMAKE_EXE_LINKER_FLAGS="-L${cuda_root}/lib -Wl,-rpath,${cuda_root}/lib"
    -DCMAKE_SHARED_LINKER_FLAGS="-L${cuda_root}/lib -Wl,-rpath,${cuda_root}/lib"
  )
fi
cmake "${cmake_args[@]}"
cmake --build /opt/nemolxd/llama-build --config Release -j"$(nproc)" --target llama-server
install -m 0755 /opt/nemolxd/llama-build/bin/llama-server /opt/nemolxd/llama-server

{
  printf 'NEMOLXD_MODEL=%q\n' "$NEMOLXD_MODEL"
  printf 'NEMOLXD_LLAMA_MODEL_PATH=%q\n' "$llama_model_path"
  printf 'NEMOLXD_API_HOST=%q\n' "$NEMOLXD_API_HOST"
  printf 'NEMOLXD_API_PORT=%q\n' "$NEMOLXD_API_PORT"
  printf 'NEMOLXD_MAX_MODEL_LEN=%q\n' "$NEMOLXD_MAX_MODEL_LEN"
  printf 'NEMOLXD_LLAMA_N_GPU_LAYERS=%q\n' "$NEMOLXD_LLAMA_N_GPU_LAYERS"
  printf 'NEMOLXD_CUDA_VARIANT=%q\n' "$NEMOLXD_CUDA_VARIANT"
} >/opt/nemolxd/env
chmod 0600 /opt/nemolxd/env

if [ -n "${HF_TOKEN:-}" ]; then
  printf 'HF_TOKEN=%s\nHUGGING_FACE_HUB_TOKEN=%s\n' "$HF_TOKEN" "$HF_TOKEN" >/opt/nemolxd/huggingface.env
  chmod 0600 /opt/nemolxd/huggingface.env
else
  : >/opt/nemolxd/huggingface.env
  chmod 0600 /opt/nemolxd/huggingface.env
fi

cat >/opt/nemolxd/start-llama.sh <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
. /opt/nemolxd/env
if [ -s /opt/nemolxd/huggingface.env ]; then
  set -a
  . /opt/nemolxd/huggingface.env
  set +a
fi
export HF_HOME=/var/lib/nemolxd/huggingface
if [ "${NEMOLXD_CUDA_VARIANT:-cu130}" = "cu130" ]; then
  export LD_LIBRARY_PATH="/opt/nemolxd/venv/lib/python3.12/site-packages/nvidia/cu13/lib:${LD_LIBRARY_PATH:-}"
fi
exec /opt/nemolxd/llama-server \
  --model "${NEMOLXD_LLAMA_MODEL_PATH:-$NEMOLXD_MODEL}" \
  --host "$NEMOLXD_API_HOST" \
  --port "$NEMOLXD_API_PORT" \
  --alias "$NEMOLXD_MODEL" \
  --ctx-size "$NEMOLXD_MAX_MODEL_LEN" \
  --n-gpu-layers "$NEMOLXD_LLAMA_N_GPU_LAYERS" \
  --reasoning off
EOF
chmod 0755 /opt/nemolxd/start-llama.sh

systemctl disable --now nemolxd-vllm.service >/dev/null 2>&1 || true

cat >/etc/systemd/system/nemolxd-llama.service <<'EOF'
[Unit]
Description=nemolxd isolated llama.cpp OpenAI-compatible endpoint
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/nemolxd
Environment=HOME=/root
Environment=PATH=/opt/nemolxd/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=/usr/bin/tini -s -- /opt/nemolxd/start-llama.sh
Restart=on-failure
RestartSec=5
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
EOF

cat >/opt/nemoclaw/openai.env <<EOF
OPENAI_BASE_URL=http://127.0.0.1:${NEMOLXD_API_PORT}/v1
OPENAI_API_KEY=nemolxd-local
OPENAI_MODEL=${NEMOLXD_MODEL}
EOF
chmod 0600 /opt/nemoclaw/openai.env

cat >/opt/nemoclaw/agent.json <<EOF
{
  "provider": "openai-compatible",
  "base_url": "http://127.0.0.1:${NEMOLXD_API_PORT}/v1",
  "api_key": "nemolxd-local",
  "model": "${NEMOLXD_MODEL}",
  "isolation": {
    "runtime": "lxd",
    "host_environment_forwarding": "disabled-by-default"
  }
}
EOF
chmod 0644 /opt/nemoclaw/agent.json

systemctl daemon-reload
systemctl enable nemolxd-llama.service
REMOTE

  printf 'installed isolated llama.cpp runtime in %s\n' "$INSTANCE"
}

cmd_start() {
  require_lxc
  lxc_exists || die "instance does not exist: $INSTANCE"
  remote_env systemctl start "$SERVICE"
  if [[ "$HOST_PORT" == "none" || -z "$HOST_PORT" ]]; then
    printf 'starting inside LXD: http://127.0.0.1:%s/v1\n' "$API_PORT"
  else
    printf 'starting: http://127.0.0.1:%s/v1\n' "$HOST_PORT"
  fi
}

wait_for_runtime() {
  remote_bash <<'REMOTE'
set -euo pipefail
. /opt/nemolxd/env
for _ in $(seq 1 120); do
  if curl -fsS "http://127.0.0.1:${NEMOLXD_API_PORT}/v1/models" >/dev/null 2>&1; then
    exit 0
  fi
  sleep 5
done
echo "llama.cpp did not become ready at http://127.0.0.1:${NEMOLXD_API_PORT}/v1/models" >&2
exit 1
REMOTE
}

cmd_stop() {
  require_lxc
  lxc_exists || die "instance does not exist: $INSTANCE"
  remote_env systemctl stop "$SERVICE"
}

cmd_status() {
  require_lxc
  lxc info "$INSTANCE" || die "instance does not exist: $INSTANCE"
  remote_env systemctl --no-pager --full status "$SERVICE" || true
}

cmd_logs() {
  require_lxc
  lxc_exists || die "instance does not exist: $INSTANCE"
  remote_env journalctl -u "$SERVICE" -f
}

cmd_test() {
  if [[ "$HOST_PORT" == "none" || -z "$HOST_PORT" ]]; then
    remote_env curl -fsS "http://127.0.0.1:${API_PORT}/v1/models"
  elif have jq; then
    curl -fsS "http://127.0.0.1:${HOST_PORT}/v1/models" | jq .
  else
    have curl || die "curl command is required for host-proxy test"
    curl -fsS "http://127.0.0.1:${HOST_PORT}/v1/models"
  fi
}

cmd_shell() {
  require_lxc
  lxc_exists || die "instance does not exist: $INSTANCE"
  remote_env bash -l
}

cmd_destroy() {
  require_lxc
  lxc_exists || {
    printf 'not found: %s\n' "$INSTANCE"
    return 0
  }
  lxc delete "$INSTANCE" --force
}

cmd_up() {
  cmd_create
  cmd_install
  cmd_start
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --instance) INSTANCE="${2:?missing value}"; shift 2 ;;
    --image) IMAGE="${2:?missing value}"; shift 2 ;;
    --model) MODEL="${2:?missing value}"; shift 2 ;;
    --tokenizer) TOKENIZER="${2:?missing value}"; shift 2 ;;
    --hf-config-path) HF_CONFIG_PATH="${2:?missing value}"; shift 2 ;;
    --hf-overrides) HF_OVERRIDES="${2:?missing value}"; shift 2 ;;
    --gguf-file) GGUF_FILE="${2:?missing value}"; shift 2 ;;
    --api-port) API_PORT="${2:?missing value}"; shift 2 ;;
    --host-port) HOST_PORT="${2:?missing value}"; shift 2 ;;
    --gpu-id) GPU_ID="${2:?missing value}"; shift 2 ;;
    --tp-size) TP_SIZE="${2:?missing value}"; shift 2 ;;
    --max-model-len) MAX_MODEL_LEN="${2:?missing value}"; shift 2 ;;
    --vllm-version) shift 2 ;;
    --cuda-variant) CUDA_VARIANT="${2:?missing value}"; shift 2 ;;
    --llama-cpp-tag) LLAMA_CPP_TAG="${2:?missing value}"; shift 2 ;;
    --n-gpu-layers) LLAMA_N_GPU_LAYERS="${2:?missing value}"; shift 2 ;;
    --pass-hf-token) PASS_HF_TOKEN=1; shift ;;
    -h|--help) usage; exit 0 ;;
    --) shift; break ;;
    -*) die "unknown option: $1" ;;
    *) break ;;
  esac
done

if [[ -z "$HF_OVERRIDES" && "$MODEL" == "unsloth/Qwen3.6-35B-A3B-GGUF:"* ]]; then
  HF_OVERRIDES='{"architectures":["Qwen3MoeForCausalLM"],"model_type":"qwen3_moe"}'
fi

COMMAND="${1:-}"
[[ -n "$COMMAND" ]] || {
  usage
  exit 2
}
shift || true

case "$COMMAND" in
  init-host) cmd_init_host "$@" ;;
  doctor) cmd_doctor "$@" ;;
  create) cmd_create "$@" ;;
  install) cmd_install "$@" ;;
  up) cmd_up "$@" ;;
  start) cmd_start "$@" ;;
  stop) cmd_stop "$@" ;;
  status) cmd_status "$@" ;;
  logs) cmd_logs "$@" ;;
  test) cmd_test "$@" ;;
  shell) cmd_shell "$@" ;;
  destroy) cmd_destroy "$@" ;;
  help) usage ;;
  *) die "unknown command: $COMMAND" ;;
esac
