# Copy this file to .env and fill in the values you need.
# .env is ignored by git.

# Hugging Face
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=

# Brave Search
BRAVE_API_KEY=
# Optional alias if your environment already uses this name.
BRAVE_SEARCH_API_KEY=

# Slack
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_CHANNEL_ID=

# Host user mapping
# Set these to the user that owns this checkout on the host, for example: id -u / id -g
NEMOCLAW_UID=1000
NEMOCLAW_GID=1000
NEMOCLAW_DOCKER_GID=138

# GitHub CLI
GH_TOKEN=
# Optional alias if your environment already uses this name.
GITHUB_TOKEN=

# OpenClaw sandbox
NEMOCLAW_SANDBOX_IMAGE=openclaw-sandbox-common:bookworm-slim
NEMOCLAW_SANDBOX_CONTAINER_PREFIX=claw-coder-sandbox

# Character name
NEMOCLAW_CHARACTER_NAME=Clawくん

# Model
# Leave this at 35B by default, or change it to the 9B repo for low-VRAM testing.
# The selected model id is used to look up defaults in config/model-settings.yaml and is passed to both the control and inference containers.
NEMOCLAW_MODEL=deepreinforce-ai/Ornith-1.0-35B-GGUF:Q4_K_M
# NEMOCLAW_MODEL=deepreinforce-ai/Ornith-1.0-9B-GGUF:Q4_K_M

# llama.cpp server image
NEMOCLAW_LLAMA_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda12

# Optional chat template override for llama.cpp tool use
NEMOCLAW_LLAMA_CHAT_TEMPLATE=
